% subplot(5,1,5); hold on; grid on;
% title('Roda Traseira Esquerda');
% 
% plot(t_drop_teo, u_drop, 'k', 'LineWidth', 1.5, 'DisplayName', 'Entrada (DROP)');
% 
% for i = 1:nP
