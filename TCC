    % Vertical roda FE (Zofe)
    A(2,2) = (m_nsf)*s^2 + (B_f+B_tf)*s + k_f + k_tf;
    A(2,5) = -((B_f)*s + (k_f));
    A(2,6) = -((B_f*d_fr)*s + (k_f*d_fr)); 
    A(2,7) = (B_f*l_f)*s + (k_f*l_f);

    % Vertical roda TD (Zotd)
    A(3,3) = (m_nsr)*s^2 + (B_r+B_tr)*s + k_r + k_tr;
