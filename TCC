%% =========================================================
% ANALISE COMPARATIVA MULTI-CLASSE E MULTI-VELOCIDADE
% Metodo: 7GDL completo no dominio da frequencia
%
% Para sistemas lineares com entrada estocastica de PSD Gd_t(f):
%   PSD_saida(f) = |H(f)|^2 * Gd_t(f)
%   RMS_banda = sqrt( integral_{f1}^{f2} |H(f)|^2 * Gd_t(f) df )
%
% H(f) = FRF do CG para entrada em todas as rodas (superposicao)
% obtida por freqresp() sobre o G do 7GDL ja construido.
%
% Classes ISO 8608:2016 Tabela 1 (valores geometricos medios corretos):
%   C: 16e-6  D: 64e-6  E: 256e-6  F: 1024e-6  [m^3]
% =========================================================

fprintf('\n=== ANALISE MULTI-CLASSE 7GDL (dominio da frequencia) ===\n');

% --- Classes de pista com Gd0 corretos per ISO 8608:2016 Tabela C.2 (n0=0,1 ciclos/m) ---
% Medias geometricas: C=256, D=1024, E=4096, F=16384 x10^-6 m^3
classes_nome = {'C',    'D',     'E',     'F'    };
Gd0_classes  = [256e-6, 1024e-6, 4096e-6, 16384e-6];
n_cls = length(classes_nome);

% --- Velocidades ---
vel_kmh   = [10, 21, 32, 43, 54];
vel_ms    = vel_kmh / 3.6;
vel_labels = arrayfun(@(v) sprintf('%d km/h', v), vel_kmh, 'UniformOutput', false);
n_vel     = length(vel_ms);

% --- Grade de frequencias para avaliacao da FRF (1 a 80 Hz, 500 pontos) ---
f_eval = linspace(1, 80, 500);
w_eval = 2*pi*f_eval;

% --- Bandas (reutiliza fc, f1, f2 da analise principal) ---
fc_mc = fc;   f1_mc = f1;   f2_mc = f2;
n_bands = length(fc_mc);
lim_mc = lim_fadiga;

% --- Pre-computa FRF do CG para cada pressao ---
fprintf('  Pre-computando FRF 7GDL para %d pressoes...\n', nP);
H_fd_arr = zeros(nP, length(f_eval), 'like', 1+1j);
H_td_arr = zeros(nP, length(f_eval), 'like', 1+1j);

for ip = 1:nP
    G_ip = G_7dof{ip};
    % Soma das colunas dianteiras e traseiras do CG (linha 5 de G)
    H_fd = squeeze(freqresp(G_ip(5,1) + G_ip(5,2), w_eval));
    H_td = squeeze(freqresp(G_ip(5,3) + G_ip(5,4), w_eval));
    % Converte deslocamento -> aceleracao: multiplica por (jw)^2 = -w^2
    H_fd_arr(ip,:) = H_fd(:).' .* (-w_eval);  % coluna -> linha
    H_td_arr(ip,:) = H_td(:).' .* (-w_eval);
    H_fd_arr(ip,:) = H_fd_arr(ip,:) .* (-w_eval);  % segundo -w^2
    H_td_arr(ip,:) = H_td_arr(ip,:) .* (-w_eval);
end
fprintf('  FRF pre-computadas.\n');

% --- Loop principal ---
idx_mc = zeros(n_cls, n_vel, nP);

for ic = 1:n_cls
    Gd0_mc = Gd0_classes(ic);

    for iv = 1:n_vel
        v_mc = vel_ms(iv);
        t_atraso_mc = (l_f + l_r) / v_mc;

        % PSD temporal da pista na grade f_eval
        n_road = max(min(f_eval / v_mc, n_max), n_min);
        Gd_t_eval = Gd0_mc * (n_road / n0).^(-psd_exp) / v_mc;

        for ip = 1:nP
            % FRF total com atraso de fase do eixo traseiro
            phase_delay = exp(-1j * w_eval * t_atraso_mc);
            H_total = H_fd_arr(ip,:) + H_td_arr(ip,:) .* phase_delay;

            % PSD da aceleracao do CG
            PSD_cg = abs(H_total).^2 .* Gd_t_eval;

            % RMS por banda integrando PSD_cg (rigoroso)
            rms_b = zeros(n_bands, 1);
            for kb = 1:n_bands
                mask = (f_eval >= f1_mc(kb)) & (f_eval < f2_mc(kb));
                if sum(mask) >= 2
                    rms_b(kb) = sqrt(trapz(f_eval(mask), PSD_cg(mask)));
                end
            end

            % Determina tempo admissivel ISO 2631/78 fadiga
            idx_ok = 0;
            for jt = 1:size(lim_mc, 2)
                if all(rms_b <= lim_mc(:, jt))
                    idx_ok = jt;  break;
                end
            end
            idx_mc(ic, iv, ip) = idx_ok;
        end
    end
    fprintf('  Classe %s concluida.\n', classes_nome{ic});
end

% Converte para escala de exibicao (maior = melhor conforto)
escala_mc = zeros(n_cls, n_vel, nP);
for ic = 1:n_cls
    for iv = 1:n_vel
        for ip = 1:nP
            v = idx_mc(ic, iv, ip);
            escala_mc(ic, iv, ip) = (v == 0)*0 + (v > 0)*(10 - v);
        end
    end
end

