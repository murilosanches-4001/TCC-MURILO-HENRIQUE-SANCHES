    A(6,6) = (I_z)*s^2 + (B_f*d_fl^2 + B_r*d_rl^2 + B_f*d_fr^2 + B_r*d_rr^2)*s + (k_f*d_fl^2 + k_r*d_rl^2 + k_f*d_fr^2 + k_r*d_rr^2);
    A(6,7) = -((d_fr-d_fl)*B_f*l_f - B_r*l_r*(d_rr-d_rl))*s + ((d_fr-d_fl)*(k_f*l_f) - (d_rr-d_rl)*k_r*l_r);

