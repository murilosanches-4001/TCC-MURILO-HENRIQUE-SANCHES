if ~exist('f_eval','var')
    f_eval = linspace(1, 80, 500);
    w_eval = 2*pi*f_eval;
end

% Gd0 Classe F (n0=0.1 ciclos/m, ISO 8608:2016 Tabela C.2)
Gd0_F = 16384e-6;

% Reutiliza H_fd_arr e H_td_arr do bloco multi-classe se ja calculados,
% caso contrario calcula aqui com G_7dof
if ~exist('H_fd_arr','var')
    H_fd_arr = zeros(nP, length(f_eval), 'like', 1+1j);
    H_td_arr = zeros(nP, length(f_eval), 'like', 1+1j);
    for ip = 1:nP
        G_ip = G_7dof{ip};
        H_fd = squeeze(freqresp(G_ip(5,1) + G_ip(5,2), w_eval));
        H_td = squeeze(freqresp(G_ip(5,3) + G_ip(5,4), w_eval));
        H_fd_arr(ip,:) = H_fd(:).' .* (-w_eval) .* (-w_eval);
        H_td_arr(ip,:) = H_td(:).' .* (-w_eval) .* (-w_eval);
    end
end

idx_tempo_vp = zeros(nP, nV);

fprintf('\n=== ANALISE PARAMETRICA DE VELOCIDADE (7GDL, dominio frequencia) ===\n');
fprintf('Classe F  |  Gd0 = %.0fe-6 m^3  |  ISO 2631/78 fadiga\n', Gd0_F*1e6);
fprintf('%-10s', 'psi\v');
for jv = 1:nV
    fprintf('  %5.0f km/h', velocidades_kmh(jv));
end
fprintf('\n');

for ip = 1:nP
    fprintf('%4d psi  ', pressao(ip));

    for jv = 1:nV
        v_vp = velocidades(jv);
        t_atraso_vp = (l_f + l_r) / v_vp;

        % PSD temporal da pista Classe F nesta velocidade
        n_road = max(min(f_eval / v_vp, n_max), n_min);
        Gd_t = Gd0_F * (n_road / n0).^(-psd_exp) / v_vp;

        % FRF total com atraso de fase do eixo traseiro
        phase_vp = exp(-1j * w_eval * t_atraso_vp);
        H_tot    = H_fd_arr(ip,:) + H_td_arr(ip,:) .* phase_vp;

        % RMS por banda integrando |H|^2 * Gd_t
        rms_b_vp = zeros(length(fc), 1);
        for kb = 1:length(fc)
            mask = (f_eval >= f1(kb)) & (f_eval < f2(kb));
