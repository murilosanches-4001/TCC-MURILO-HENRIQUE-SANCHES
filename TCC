    A(5,6) = ((d_fl-d_fr)*B_f +(d_rl-d_rr)*B_r)*s + ((d_fl-d_fr)*k_f + (d_rl-d_rr)*k_r);
    A(5,7) = 2*((l_f*B_f-l_r*B_r)*s+(l_f*k_f-l_r*k_r));

    % Angulo Roll (Alpha)
