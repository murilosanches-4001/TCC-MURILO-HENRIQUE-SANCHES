%% ---------------------------------------------------------
% 1) RMS por banda para CG, FD e TD
% ----------------------------------------------------------
rms_CG = zeros(length(fc), nP);
rms_FD = zeros(length(fc), nP);
rms_TD = zeros(length(fc), nP);

for ip = 1:nP

    a_cg = detrend(A_cg_iso_ms2(:,ip), 0);
    a_fd = detrend(A_fd_iso_ms2(:,ip), 0);
    a_td = detrend(A_td_iso_ms2(:,ip), 0);

    rms_CG(:,ip) = calcula_rms_bandas(a_cg, fs_iso, fc, f1, f2);
    rms_FD(:,ip) = calcula_rms_bandas(a_fd, fs_iso, fc, f1, f2);
    rms_TD(:,ip) = calcula_rms_bandas(a_td, fs_iso, fc, f1, f2);
end

%% ---------------------------------------------------------
% 2) Frequencias naturais estimadas por pressao
% ----------------------------------------------------------
f_heave = zeros(nP,1);      % massa suspensa, vertical aproximada
f_wheel_F = zeros(nP,1);    % massa nao suspensa dianteira
f_wheel_R = zeros(nP,1);    % massa nao suspensa traseira

banda_heave = zeros(nP,1);
banda_wheel_F = zeros(nP,1);
banda_wheel_R = zeros(nP,1);

for ip = 1:nP

    k_tf = rig_p2(ip);   % pneu dianteiro
    k_tr = rig_p1(ip);   % pneu traseiro

    % rigidez equivalente suspensao + pneu em serie
    k_eq_f = (k_f * k_tf)/(k_f + k_tf);
    k_eq_r = (k_r * k_tr)/(k_r + k_tr);

    % modo vertical aproximado da massa suspensa
    f_heave(ip) = (1/(2*pi))*sqrt((2*k_eq_f + 2*k_eq_r)/M_s);

    % modo de massa nao suspensa, ou wheel hop aproximado
    f_wheel_F(ip) = (1/(2*pi))*sqrt((k_f + k_tf)/m_nsf);
    f_wheel_R(ip) = (1/(2*pi))*sqrt((k_r + k_tr)/m_nsr);

    % banda de 1/3 de oitava mais proxima
    [~,idxH] = min(abs(log(fc/f_heave(ip))));
    [~,idxF] = min(abs(log(fc/f_wheel_F(ip))));
    [~,idxR] = min(abs(log(fc/f_wheel_R(ip))));

    banda_heave(ip) = fc(idxH);
    banda_wheel_F(ip) = fc(idxF);
    banda_wheel_R(ip) = fc(idxR);
end

%% ---------------------------------------------------------
% 3) Banda dominante da resposta para cada pressao
% ----------------------------------------------------------
banda_dom_CG = zeros(nP,1);
banda_dom_FD = zeros(nP,1);
banda_dom_TD = zeros(nP,1);

rms_dom_CG = zeros(nP,1);
rms_dom_FD = zeros(nP,1);
rms_dom_TD = zeros(nP,1);

for ip = 1:nP
    [rms_dom_CG(ip), idxCG] = max(rms_CG(:,ip));
    [rms_dom_FD(ip), idxFD] = max(rms_FD(:,ip));
    [rms_dom_TD(ip), idxTD] = max(rms_TD(:,ip));

    banda_dom_CG(ip) = fc(idxCG);
    banda_dom_FD(ip) = fc(idxFD);
    banda_dom_TD(ip) = fc(idxTD);
end


D_FD = zeros(nP,1);
D_TD = zeros(nP,1);

for ip = 1:nP

    % seleciona bandas proximas ao wheel-hop dianteiro e traseiro
    % +/- 1 banda de 1/3 de oitava em torno da frequencia estimada
    sel_F = abs(log2(fc/f_wheel_F(ip))) <= 1/3;
    sel_R = abs(log2(fc/f_wheel_R(ip))) <= 1/3;

    % forca inercial RMS aproximada por banda
    F_FD = m_nsf * rms_FD(sel_F,ip);   % [N]
    F_TD = m_nsr * rms_TD(sel_R,ip);   % [N]

    % numero aproximado de ciclos por banda no tempo simulado
    N_F = fc(sel_F)' * T_iso;
    N_R = fc(sel_R)' * T_iso;

    % indice relativo
    D_FD(ip) = sum((F_FD.^m_fad).*N_F);
    D_TD(ip) = sum((F_TD.^m_fad).*N_R);
end

% normalizacao para facilitar comparacao
D_FD_rel = D_FD/min(D_FD);
D_TD_rel = D_TD/min(D_TD);

D_total_rel = (D_FD_rel + D_TD_rel)/2;

