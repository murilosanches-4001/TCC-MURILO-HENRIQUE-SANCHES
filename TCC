% ----------------------------------------------------------
% 4) RMS por banda de 1/3 de oitava e tempo admissivel
%    Metodo: ISO 2631/78 secao 4.2.4 -- "Vibracao de banda larga"
%    Para cada banda de 1/3 de oitava: calcular RMS da aceleracao do CG
%    e comparar ao limite tabelado na frequencia central daquela banda.
%    O criterio de tempo admissivel e a coluna mais conservadora (menor
%    tempo) cujos limites NAO sao excedidos em nenhuma banda.
% ----------------------------------------------------------


rms_bandas = zeros(length(fc), nP);
tempo_admissivel = strings(1,nP);

for ip = 1:nP

    % aceleracao vertical do CG para a pressao ip
    a = A_cg_iso_ms2(:,ip);
    a = a(:);

    % remove media
    a = detrend(a, 0);

    % PSD do sinal
    nfft = 16384;
    noverlap = round(nfft/2);
    [Pxx, f] = pwelch(a, hamming(nfft), noverlap, nfft, fs_iso);

    % RMS por banda de 1/3 de oitava via integracao da PSD
    for k = 1:length(fc)
        idx = (f >= f1(k)) & (f < f2(k));

        if sum(idx) < 2
    rms_bandas(k,ip) = 0;
else
    rms_bandas(k,ip) = sqrt(trapz(f(idx), Pxx(idx)));
end
    end

    % determina maior tempo admissivel
    idx_ok = [];
    for jt = 1:size(limites,2)   % 24h -> 1min
        if all(rms_bandas(:,ip) <= limites(:,jt))
            idx_ok = jt;
            break;
        end
    end

    if isempty(idx_ok)
        tempo_admissivel(ip) = "< 1 min";
    else
