    A(7,5) = ((2*l_f*B_f-2*l_r*B_r)*s+(2*l_f*k_f-2*l_r*k_r));
    A(7,6) = -((d_fl-d_fr)*B_f*l_f - B_r*l_r*(d_rl-d_rr))*s + ((d_fl-d_fr)*(k_f*l_f) - (d_rl-d_rr)*k_r*l_r);
    A(7,7) = (I_x)*s^2 + (2*B_f*l_f^2 + 2*B_r*l_r^2)*s + (2*k_f*l_f^2 + 2*k_r*l_r^2);

    % Matriz de transferencia da base para as saidas
    % Entrada na base compativel com rigidez e amortecimento do pneu
    Bbase = tf(zeros(7,4));
    Bbase(1,1) = B_tf*s + k_tf;
    Bbase(2,2) = B_tf*s + k_tf;
    Bbase(3,3) = B_tr*s + k_tr;
    Bbase(4,4) = B_tr*s + k_tr;

    G = inv(A) * Bbase;

    % Salva G completo para reuso na analise multi-classe (sem reconstruir a matriz)
    G_7dof{i} = G;  % cell array indexado por pressao

    % Output de cada GDL para entrada de deslocamento na roda FD
    zofd_ifd = G(1,1);
    zofe_ifd = G(2,1);
    zotd_ifd = G(3,1);
    zote_ifd = G(4,1);
    zoc_ifd = G(5,1);
    alpha_ifd = G(6,1);
    beta_ifd = G(7,1);

    % Output de cada GDL para entrada de deslocamento na roda FE
    zofd_ife = G(1,2);
    zofe_ife = G(2,2);
    zotd_ife = G(3,2);
    zote_ife = G(4,2);
    zoc_ife = G(5,2);
    alpha_ife = G(6,2);
    beta_ife = G(7,2);

