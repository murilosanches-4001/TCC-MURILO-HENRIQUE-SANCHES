function a = diff2_central(y, ts)
    % Segunda derivada por diferenca central
    a = zeros(size(y));
    a(2:end-1) = (y(3:end) - 2*y(2:end-1) + y(1:end-2)) / ts^2;
end
function rms_b = calcula_rms_bandas(a, fs, fc, f1, f2)
    % Calcula RMS por banda de 1/3 de oitava via integracao da PSD (Welch).
    % nfft e limitado para equilibrar resolucao espectral e velocidade:
    %   - minimo para resolver 1 Hz: fs/1 amostras -> nfft = potencia de 2 acima disso
    %   - maximo: 16384 (mais que suficiente para resolucao em 1 Hz)

    a = a(:);
    a = detrend(a, 0);

    % Resolucao minima necessaria: 1 Hz (banda mais baixa da norma e 1 Hz)
    nfft_min = 2^ceil(log2(fs / 1));   % potencia de 2 >= fs pontos
    nfft = min(nfft_min, 16384);       % nunca excede 16384

    if length(a) < nfft
        nfft = 2^floor(log2(length(a)));
    end

    noverlap = round(nfft / 2);
    [Pxx, f] = pwelch(a, hamming(nfft), noverlap, nfft, fs);

    rms_b = zeros(length(fc), 1);
    for k = 1:length(fc)
        idx = (f >= f1(k)) & (f < f2(k));
        if sum(idx) < 2
            rms_b(k) = 0;
        else
            rms_b(k) = sqrt(trapz(f(idx), Pxx(idx)));
        end
    end
end
